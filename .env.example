# API Configuration
GROQ_API_KEY=your_groq_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here

# Optional: Default branch name prefix for refactoring
REFAC_BRANCH_PREFIX=refactor/

# Optional: LLM Model selection (Groq model id)
# llama-3.1-70b-versatile and llama-3.3-70b-versatile have both been
# deprecated by Groq. Check https://console.groq.com/docs/models for the
# current list before relying on this default.
LLM_MODEL=openai/gpt-oss-120b
