# API Configuration
GROQ_API_KEY=your_groq_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here

# Optional: Default branch name prefix for refactoring
REFAC_BRANCH_PREFIX=refactor/

# Optional: LLM Model selection (Groq models)
LLM_MODEL=llama-3.1-70b-versatile
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma-7b-it